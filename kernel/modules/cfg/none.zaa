//
// no cfg
//

import std.stdio;
import cfg.pci;
import platform;

import pci;
import ps2;

pub fn initialise() -> void
{
}

pub fn coldplug() -> void
{
  ps2::initialise();
  pci::initialise();

  for (var &device : pci::devices)
  {
    cfg::coldplug(device);
  }
}

pub fn reboot() -> void
{
  std::panic("reboot");
}

pub fn poweroff() -> void
{
  std::panic("poweroff");
}
